{
  "manifest_version": 3,
  "name": "AIXLINX 物件検索",
  "version": "1.5.6",
  "description": "お客さんの条件に合わせてリアプロ・itandi・レインズを検索するサポートツール",
  "action": {
    "default_title": "AIXLINX 物件検索"
  },
  "side_panel": {
    "default_path": "popup.html"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "host_permissions": [
    "https://sumora-ai-ui.vercel.app/*",
    "https://www.realnetpro.com/*",
    "https://itandibb.com/*"
  ],
  "permissions": [
    "sidePanel",
    "tabs",
    "clipboardWrite"
  ],
  "web_accessible_resources": [
    {
      "resources": ["popup.html", "popup.js", "styles.css", "page-script.js"],
      "matches": ["https://www.realnetpro.com/*", "https://itandibb.com/*"]
    },
    {
      "resources": ["itandi-page-script.js"],
      "matches": ["https://itandibb.com/*"]
    }
  ],
  "content_scripts": [
    {
      "matches": ["https://www.realnetpro.com/*"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_start"
    },
    {
      "matches": ["https://www.realnetpro.com/*"],
      "js": ["underbar.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://www.realnetpro.com/*"],
      "js": ["bulk-dl.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://itandibb.com/*"],
      "js": ["underbar.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://itandibb.com/*"],
      "js": ["itandi-content.js"],
      "run_at": "document_idle"
    }
  ]
}
