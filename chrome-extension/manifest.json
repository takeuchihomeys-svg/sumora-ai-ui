{
  "manifest_version": 3,
  "name": "AIXLINX 物件検索",
  "version": "1.2.0",
  "description": "お客さんの条件に合わせてリアプロ・itandi・レインズを検索するサポートツール",
  "action": {
    "default_title": "AIXLINX 物件検索"
  },
  "side_panel": {
    "default_path": "popup.html"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "host_permissions": [
    "https://sumora-ai-ui.vercel.app/*",
    "https://www.realnetpro.com/*"
  ],
  "permissions": [
    "sidePanel"
  ],
  "content_scripts": [
    {
      "matches": ["https://www.realnetpro.com/*"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_start"
    }
  ]
}
